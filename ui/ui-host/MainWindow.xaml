<Window
    x:Class="Flowtile.UiHost.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Flowtile.UiHost"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Flowtile UI Host">
    <Grid Background="#FFF3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Margin="24,24,24,12"
            Padding="24"
            Background="#FF0F172A"
            CornerRadius="24">
            <Grid ColumnSpacing="18" RowSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock
                        FontSize="32"
                        FontWeight="SemiBold"
                        Foreground="#FFF8FAFC"
                        Text="Flowtile UI Host" />
                    <TextBlock
                        MaxWidth="840"
                        Foreground="#FFCBD5E1"
                        Text="Projection-driven shell host поверх daemon: overview, diagnostics и базовый control surface строятся только из snapshot и event stream."
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="14,10"
                    Background="#3310B981"
                    BorderBrush="#FF10B981"
                    BorderThickness="1"
                    CornerRadius="999">
                    <StackPanel>
                        <TextBlock
                            HorizontalAlignment="Center"
                            Foreground="#FFA7F3D0"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Transport" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="#FFF8FAFC"
                            Text="{x:Bind State.ConnectionBadge, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Button Click="FocusPrevButton_Click" Content="Focus Prev" />
                    <Button Click="FocusNextButton_Click" Content="Focus Next" />
                    <Button Click="ScrollLeftButton_Click" Content="Scroll Left" />
                    <Button Click="ScrollRightButton_Click" Content="Scroll Right" />
                    <Button Click="ToggleOverviewButton_Click" Content="Toggle Overview" />
                    <Button Click="ReloadConfigButton_Click" Content="Reload Config" />
                    <Button Click="OpenDiagnosticsButton_Click" Content="Open Diagnostics" />
                </StackPanel>

                <Grid
                    Grid.Row="2"
                    Grid.ColumnSpan="2"
                    ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="16"
                        Background="#1E293BCC"
                        CornerRadius="18">
                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="#FF93C5FD"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Focus" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFF8FAFC"
                                Text="{x:Bind State.FocusSummary, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="16"
                        Background="#1E293BCC"
                        CornerRadius="18">
                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="#FFFDE68A"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Overview" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFF8FAFC"
                                Text="{x:Bind State.OverviewSummary, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="#1E293BCC"
                        CornerRadius="18">
                        <StackPanel Spacing="6">
                            <TextBlock
                                Foreground="#FFC4B5FD"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Runtime" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#FFF8FAFC"
                                Text="{x:Bind State.VersionLine, Mode=OneWay}" />
                            <TextBlock
                                Foreground="#FFCBD5E1"
                                Text="{x:Bind State.RuntimeMode, Mode=OneWay}" />
                            <TextBlock
                                Foreground="#FFCBD5E1"
                                Text="{x:Bind State.ConfigSummary, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24,0,24,12"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="4">
                    <TextBlock
                        Foreground="#FF475569"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Outputs" />
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind State.OutputSummary, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="4">
                    <TextBlock
                        Foreground="#FF475569"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Workspaces" />
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind State.WorkspaceSummary, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="16"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="18">
                <StackPanel Spacing="4">
                    <TextBlock
                        Foreground="#FF475569"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Windows" />
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="{x:Bind State.WindowSummary, Mode=OneWay}" />
                    <TextBlock
                        Foreground="#FF64748B"
                        Text="{x:Bind State.LastCommand, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            Grid.Row="2"
            Margin="24,0,24,24"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Grid.Column="0"
                Padding="18"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="20">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Outputs" />
                        <TextBlock
                            Foreground="#FF64748B"
                            Text="Projection of monitor topology from daemon." />
                    </StackPanel>
                    <ListView
                        Grid.Row="1"
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind State.Outputs, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:OutputCard">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="#FFF8FAFC"
                                    CornerRadius="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Title}" />
                                        <TextBlock
                                            Foreground="#FF475569"
                                            Text="{x:Bind Detail}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Foreground="#FF64748B"
                                            Text="{x:Bind WorkspaceLine}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="18"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="20">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Overview / Workspaces" />
                        <TextBlock
                            Foreground="#FF64748B"
                            Text="Первый visual overview поверх snapshot/event stream." />
                    </StackPanel>
                    <ListView
                        Grid.Row="1"
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind State.Workspaces, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:WorkspaceCard">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="#FFF8FAFC"
                                    CornerRadius="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Title}" />
                                        <TextBlock
                                            Foreground="#FF475569"
                                            Text="{x:Bind Detail}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Foreground="#FF64748B"
                                            Text="{x:Bind Occupancy}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border
                Grid.RowSpan="2"
                Grid.Column="1"
                Padding="18"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="20">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="6">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Windows" />
                        <TextBlock
                            Foreground="#FF64748B"
                            Text="Текущая лента, focus и routing отображаются только из daemon projections." />
                    </StackPanel>
                    <TextBlock
                        Grid.Row="1"
                        Foreground="#FF64748B"
                        Text="{x:Bind State.LastEvent, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <ListView
                        Grid.Row="2"
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind State.Windows, Mode=OneWay}"
                        SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:WindowCard">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="14"
                                    Background="#FFF8FAFC"
                                    CornerRadius="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Title}" />
                                        <TextBlock
                                            Foreground="#FF475569"
                                            Text="{x:Bind Location}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Foreground="#FF64748B"
                                            Text="{x:Bind Detail}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
