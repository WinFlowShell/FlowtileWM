<Window
    x:Class="Flowtile.UiHost.DiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Flowtile Diagnostics">
    <Grid Background="#FF111827">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Margin="24,24,24,12"
            Padding="20"
            Background="#CC1F2937"
            BorderBrush="#FF3B82F6"
            BorderThickness="1"
            CornerRadius="20">
            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="#FFF9FAFB"
                    Text="Diagnostics Surface" />
                <TextBlock
                    Foreground="#FFD1D5DB"
                    Text="Отдельное окно читает только projection-слой daemon и не хранит собственную WM-модель." />
            </StackPanel>
        </Border>

        <Grid
            Grid.Row="1"
            Margin="24,0,24,24"
            ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Grid.Column="0"
                Padding="18"
                Background="#CC1E293B"
                CornerRadius="18">
                <StackPanel Spacing="6">
                    <TextBlock
                        Foreground="#FF93C5FD"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Transport" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFF9FAFB"
                        Text="{x:Bind State.ConnectionBadge, Mode=OneWay}" />
                    <TextBlock
                        Foreground="#FFD1D5DB"
                        Text="{x:Bind State.ConnectionDetail, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="0"
                Grid.Column="1"
                Padding="18"
                Background="#CC1E293B"
                CornerRadius="18">
                <StackPanel Spacing="6">
                    <TextBlock
                        Foreground="#FFFCA5A5"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Last Error" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFF9FAFB"
                        Text="{x:Bind State.LastError, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="18"
                Margin="0,16,0,0"
                Background="#CC1E293B"
                CornerRadius="18">
                <StackPanel Spacing="6">
                    <TextBlock
                        Foreground="#FF86EFAC"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Focus" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFF9FAFB"
                        Text="{x:Bind State.FocusSummary, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="18"
                Margin="0,16,0,0"
                Background="#CC1E293B"
                CornerRadius="18">
                <StackPanel Spacing="6">
                    <TextBlock
                        Foreground="#FFFDE68A"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Overview" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFF9FAFB"
                        Text="{x:Bind State.OverviewSummary, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Padding="18"
                Margin="0,16,0,0"
                Background="#CC1E293B"
                CornerRadius="18">
                <StackPanel Spacing="12">
                    <TextBlock
                        Foreground="#FFC4B5FD"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Diagnostics Projection" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="#FFF9FAFB"
                        Text="{x:Bind State.DiagnosticsSummary, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="#FFD1D5DB"
                        Text="{x:Bind State.ConfigSummary, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="#FFD1D5DB"
                        Text="{x:Bind State.LastCommand, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        Foreground="#FFD1D5DB"
                        Text="{x:Bind State.LastEvent, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
